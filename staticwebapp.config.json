{
  "routes": [
    {
      "route": "/en/*",
      "rewrite": "/en/index.html"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/en/*.html"]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/error.html",
      "statusCode": 404
    }
  },
  "mimeTypes": {
    ".json": "application/json"
  }
}
